# ─────────────────────────────────────────────
# LLM Provider Layer — environment variables
# Copy this file to .env and fill in the keys
# for whichever provider(s) you plan to use.
# You only need the variables for your chosen
# provider(s); the rest can stay blank.
# ─────────────────────────────────────────────

# Which provider the AI core should use by default.
# One of: openai | anthropic | gemini | groq | openrouter | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# OpenAI ─ https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_BASE_URL=

# Anthropic ─ https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Google Gemini ─ https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_BASE_URL=

# Groq ─ https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=

# OpenRouter ─ https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=

# Ollama ─ local inference, no API key required
OLLAMA_BASE_URL=http://localhost:11434

# Shared resilience defaults (all optional)
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=3

# ─────────────────────────────────────────────
# Embedding Provider Layer (Component 2)
# OpenAI/Gemini keys above are reused if you pick
# those providers for embeddings too. Cohere is
# embedding-only, so it gets its own key here.
# ─────────────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
COHERE_API_KEY=

# ─────────────────────────────────────────────
# Vector Store Layer (Component 3) — Qdrant
# QDRANT_API_KEY is only required for Qdrant
# Cloud; local/self-hosted Qdrant needs none.
# ─────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
