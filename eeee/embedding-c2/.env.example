# Embedding Provider Layer — only the variables for the provider(s) you
# actually use are required. `ollama` needs none (local development first).

# --- OpenAI ---------------------------------------------------------------
# Same key as the LLM Provider Layer if you already use OpenAI for chat.
OPENAI_API_KEY=

# --- Google Gemini ---------------------------------------------------------
# Same key as the LLM Provider Layer if you already use Gemini for chat.
GEMINI_API_KEY=

# --- Cohere ------------------------------------------------------------
# New for this component — not used by the LLM Provider Layer.
COHERE_API_KEY=

# --- Ollama (local, no key required) ---------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
